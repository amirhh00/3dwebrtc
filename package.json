    "@types/eslint": "^9.6.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.5.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.4.8",
