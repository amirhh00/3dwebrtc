    "lint": "bunx --bun prettier --check . && eslint .",
    "format": "bunx --bun prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
